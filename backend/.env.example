DATABASE_URL=sqlite:///./trading.db

BROKER_PROVIDER=simulator
MARKET_DATA_PROVIDER=yfinance

# Phase 2 (Kite Connect) - leave unset in Phase 1
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Required only for agents using the llm_recommendation strategy.
# LLM_PROVIDER picks which credential pair below is used: anthropic | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
RECOMMENDATION_MODEL=claude-opus-4-8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

SIMULATOR_SLIPPAGE_PCT=0.0
ACCOUNT_STARTING_CAPITAL=100000

# Leave both unset for local dev (no login screen). Set both in production
# to gate the app behind a single shared login - see README "Deploying".
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
